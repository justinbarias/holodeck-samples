# Integration Test Environment Variables
# Fill in your actual API keys below to run integration tests

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_NAME=gpt-4o-mini

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022
CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token-here

# Test Configuration
# Set to "true" to skip tests that require real API keys
SKIP_LLM_INTEGRATION_TESTS=false
BRAVE_API_KEY=your-brave-api-key-here
OPENSEARCH_PASSWORD=your-opensearch-password-here
