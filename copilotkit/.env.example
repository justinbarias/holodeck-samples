# HoloDeck CopilotKit Frontend — Environment Configuration
# Copy this file to .env.local and fill in your values.

# Required — must match the `name` field in your agent.yaml
AGENT_ID=my_agent

# Required — displayed in the header and browser tab
AGENT_TITLE=My Agent
AGENT_DESCRIPTION=What my agent does

# Optional — HoloDeck serve endpoint (default shown)
# HOLODECK_BACKEND_URL=http://127.0.0.1:8000/awp

# Optional — MIME types for the file upload input (default shown)
# FILE_ACCEPT=image/*,application/pdf,.doc,.docx,.txt
