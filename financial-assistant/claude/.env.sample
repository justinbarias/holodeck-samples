# Sample environment for the financial-assistant agent.
#
# Copy this to `.env` and fill in real values:
#     cp .env.sample .env
#
# Priority at runtime: shell env > .env (here) > ~/.holodeck/.env.
# Never commit `.env` to git.

# --- Claude (primary backend) ----------------------------------------------
# Anthropic API. Either ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN is
# required; the latter is preferred for Claude Code / Pro Max subscribers
# (set agent.yaml `model.auth_provider: oauth_token`).
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# --- Azure OpenAI (embeddings + context-generation) ------------------------
# Required because model.provider is anthropic and the agent uses a
# hierarchical_document tool that embeds with Azure OpenAI.
AZURE_OPENAI_API_KEY=00000000000000000000000000000000
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# --- OpenAI (fallback / alt provider) --------------------------------------
# Optional. Only needed if you swap model.provider to `openai`.
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o

# --- Vector store (Qdrant) -------------------------------------------------
# Local docker: http://localhost:6333
# Qdrant Cloud: https://<cluster>.<region>.cloud.qdrant.io:6333?api_key=<key>
QDRANT_URL=http://localhost:6333
QDRANT_REMOTE_URL=https://your-cluster.cloud.qdrant.io:6333?api_key=...

# --- Optional sparse / keyword index ---------------------------------------
# Only set if you switch keyword_index to an OpenSearch backend.
OPENSEARCH_PASSWORD=changeme

# --- Optional web search ---------------------------------------------------
BRAVE_API_KEY=...

# --- Observability (OpenTelemetry) -----------------------------------------
# Default points at a locally running .NET Aspire dashboard:
#   docker run --rm -it -p 18888:18888 -p 18889:18889 \
#     mcr.microsoft.com/dotnet/aspire-dashboard:latest
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:18889

# --- Azure Storage (optional, for blob-backed test artefacts) --------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# --- Server protocol -------------------------------------------------------
# `holodeck serve` honours this when no --protocol flag is passed.
HOLODECK_PROTOCOL=ag-ui

# --- Test toggles ----------------------------------------------------------
# Set to 1 to skip live-LLM integration tests.
SKIP_LLM_INTEGRATION_TESTS=0
